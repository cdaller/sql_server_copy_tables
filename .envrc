# .envrc (advanced reusable helper)
use_uv() {
  local pyver="${1:-3.14}"
  if ! command -v uv >/dev/null 2>&1; then
    echo "ERROR: uv not installed" >&2
    return 1
  fi
  uv python install "$pyver"
  if [ ! -d .venv ]; then
    uv venv --python "$pyver"
  fi
  PATH_add ".venv/bin"
  export VIRTUAL_ENV="$PWD/.venv"
  watch_file pyproject.toml
  watch_file uv.lock
  if [ -f uv.lock ]; then
    uv sync --frozen || uv sync
  else
    uv sync
  fi
  dotenv_if_exists
}
if [ -f .python-version ]; then
  use_uv "$(cat .python-version)"
else
  use_uv
fi